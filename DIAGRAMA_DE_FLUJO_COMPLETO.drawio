  <diagram name="Diagrama Detallado" id="VIKnTiPRf9UUrzwe8vuU">
    <mxGraphModel dx="1018" dy="781" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" background="ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="dtitulo" parent="1" style="text;html=1;fontSize=13;fontStyle=bold;fillColor=#1a237e;fontColor=#ffffff;rounded=0;spacing=10;" value="VERITUS BOT - CARACTERÍSTICAS Y DETALLES DEL SISTEMA" vertex="1">
          <mxGeometry height="40" width="770" x="50" y="20" as="geometry" />
        </mxCell>
        <mxCell id="lNz98GaVUUPX0D6qDsz1-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontColor=#ffffff;strokeColor=#2D7600;" value="&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ INICIALIZACION: Validar Horario (08:00-20:00)&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ LECTURA: Leer CSV personas, sincronizar BD personas_procesadas&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ FILTRADO: procesado=0 O (procesado=1 Y fecha_procesada &amp;gt; 6 meses)&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ PROCESAMIENTO: FASE 4.1 (Santiago) PRIMERO, marcar tribunal_principal_procesado=1, luego FASE 4.2&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ EJECUCION: ThreadPool max 3 threads, delay 5 segundos entre threads&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ AÑOS: Iterar desde AnoInit hasta AnoFin&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ WEB AUTOMATION: Chrome, PJUD, cerrar popup, Consulta Causas, Búsqueda por Nombre&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ FORMULARIO: Seleccionar Competencia, Apellido Paterno, Apellido Materno, Año&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ DROPDOWN: 231 tribunales - Click tribunal, Buscar&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ ESPERA: #loadPreNombre (timeout 10 segundos)&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ EXTRACCION: JSoup - Rol, Fecha, Caratula, Tribunal&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ ALMACENAMIENTO: CSV + BD (tabla causas y personas)&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ MARCAR: procesado=1, tribunal_principal_procesado=1, fecha_procesada=NOW()&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ LOGS: Progreso por cliente, tiempo total, timestamps HH:MM:SS&lt;/span&gt;&lt;br style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 9px; text-align: left; text-wrap-mode: nowrap;&quot;&gt;✓ MODOS: desarrollo (detallados), produccion (esenciales), pruebas (muy detallados)&lt;/span&gt;" vertex="1">
          <mxGeometry height="300" width="770" x="50" y="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
